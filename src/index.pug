doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title 第Ｎ曜日 - 繰り返し曜日の日付一覧
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Sans", "Noto Sans JP", sans-serif;
        background: #f0f4f8;
        color: #1a202c;
        min-height: 100vh;
      }
      header {
        background: linear-gradient(135deg, #4c51bf, #6b46c1);
        color: #fff;
        padding: 3rem 1.5rem 2.5rem;
        text-align: center;
      }
      header h1 {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: 0.02em;
      }
      header p {
        margin-top: 0.75rem;
        font-size: 1.05rem;
        opacity: 0.9;
        line-height: 1.6;
      }
      .card {
        background: #fff;
        max-width: 600px;
        margin: -1.5rem auto 2rem;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        padding: 2rem;
      }
      .form-section {
        margin-bottom: 1.5rem;
      }
      .form-section:last-child { margin-bottom: 0; }
      .form-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
      }
      .weekday-row {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
        font-size: 1.1rem;
        line-height: 2.4;
      }
      .weekday-row span {
        white-space: nowrap;
      }
      select, input[type="text"], input[name="summary"],
      input[name="start_at"], input[name="end_at"] {
        font-size: 1rem;
        padding: 0.45rem 0.6rem;
        border: 1.5px solid #d1d5db;
        border-radius: 6px;
        background: #fff;
        color: #1a202c;
        transition: border-color 0.2s;
        font-family: inherit;
      }
      select:focus, input:focus {
        outline: none;
        border-color: #6b46c1;
        box-shadow: 0 0 0 3px rgba(107,70,193,0.15);
      }
      .format-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }
      .ical-section {
        background: #f9fafb;
        border-radius: 8px;
        padding: 1rem 1.25rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
      }
      .ical-section .field { display: flex; flex-direction: column; gap: 0.25rem; }
      .ical-section .field.full { grid-column: 1 / -1; }
      .ical-section label {
        font-size: 0.8rem;
        color: #6b7280;
        font-weight: 500;
      }
      .ical-section input {
        width: 100%;
      }
      button[type="submit"] {
        display: block;
        width: 100%;
        padding: 0.85rem;
        font-size: 1.05rem;
        font-weight: 600;
        color: #fff;
        background: linear-gradient(135deg, #4c51bf, #6b46c1);
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: opacity 0.2s;
        font-family: inherit;
      }
      button[type="submit"]:hover { opacity: 0.9; }
      footer {
        text-align: center;
        padding: 1.5rem;
        font-size: 0.85rem;
        color: #9ca3af;
      }
      footer a { color: #6b46c1; text-decoration: none; }
      footer a:hover { text-decoration: underline; }
      @media (max-width: 640px) {
        header { padding: 2rem 1rem 2rem; }
        header h1 { font-size: 1.5rem; }
        .card { margin: -1rem 0.75rem 1.5rem; padding: 1.5rem; }
        .ical-section { grid-template-columns: 1fr; }
      }

  body
    header
      h1 第Ｎ曜日
      p 「第2・第4木曜日」のような繰り返し曜日の日付一覧を取得

    .card
      form(action="/api/week" method="get")
        .form-section
          span.form-label 日付の条件
          .weekday-row
            select(name="year")
              option 2024
              option 2025
              option(selected) 2026
              option 2027
              option 2028
            span 年
            span &ensp;第
            select(name="num")
              option 1
              option 2
              option 3
              option 4
              option 5
            span ・第
            select(name="num2")
              option(value="")  -
              option 1
              option 2
              option 3
              option 4
              option 5
            span &ensp;
            select(name="wday")
              option(value="su") 日
              option(value="mo") 月
              option(value="tu") 火
              option(value="we") 水
              option(value="th") 木
              option(value="fr") 金
              option(value="sa") 土
            span 曜日

        .form-section
          span.form-label 出力フォーマット
          .format-row
            select(name="format")
              option html
              option csv
              option json
              option js
              option ical

        .form-section
          span.form-label iCal オプション
          .ical-section
            .field.full
              label 予定名
              input(name="summary" placeholder="例: 定例ミーティング")
            .field
              label 開始時刻
              input(name="start_at" value="8:00")
            .field
              label 終了時刻
              input(name="end_at" value="8:00")

        .form-section
          button(type="submit") 取得する

    footer
      | 前後1年、計3年分の日付を一覧表示します &middot;
      a(href="https://github.com/kuboon/cal.kbn.one") GitHub
